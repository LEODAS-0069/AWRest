# Environment Configuration
# Copy this file to .env and fill in your actual values

FLASK_ENV=development

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=labubu_listings

# PostgreSQL (for chatbot query logging)
DATABASE_URL=postgresql://labubu_user:labubu_password@localhost:5432/labubu_chatbot

# DynamoDB (AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
DYNAMODB_ORDERS_TABLE=labubu_orders

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Service URLs
TORNADO_SERVICE_URL=http://localhost:8001
CHATBOT_SERVICE_URL=http://localhost:7860

# Flask
SECRET_KEY=your-secret-key-change-in-production
