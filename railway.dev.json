// Railway development environment configuration
{
  "$schema": "https://railway.app/json-schema/railway-schema.json",
  
  "build": {
    "builder": "nixpacks"
  },
  
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT --workers 4 backend.app.api_gateway:app",
    "healthchecks": {
      "liveness": {
        "type": "http",
        "path": "/health",
        "initialDelaySeconds": 15,
        "periodSeconds": 30,
        "timeoutSeconds": 5,
        "failureThreshold": 3
      },
      "readiness": {
        "type": "http",
        "path": "/health",
        "initialDelaySeconds": 10,
        "periodSeconds": 10,
        "timeoutSeconds": 3
      }
    }
  },
  
  "services": {
    "mongo": {
      "image": "mongo:6.0"
    },
    "postgres": {
      "image": "postgres:15-alpine",
      "variables": {
        "POSTGRES_USER": "labubu_user",
        "POSTGRES_DB": "labubu_chatbot"
      }
    }
  }
}
